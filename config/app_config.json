
{
  "app_name": "Renombrador PDF Hospitalario",
  "database": {
    "sqlite_path": "config/catalogo_reglas.db",
    "seed_sql_path": "datos_base/nombres_validos.sql"
  },
  "pdf": {
    "extract_pages": 5,
    "max_chars": 50000
  },
  "built_in_rules": [
    {
      "type": "filename_contains",
      "pattern": "PLANILLA",
      "target": "PI.pdf",
      "reason": "Regla heredada: PLANILLA -> PI.pdf",
      "score": 90
    },
    {
      "type": "filename_contains",
      "pattern": "OTROS",
      "target": "ORS.pdf",
      "reason": "Regla heredada: OTROS -> ORS.pdf",
      "score": 90
    },
    {
      "type": "text_contains",
      "pattern": "NOTASDEEVOLUCION",
      "target": "002.pdf",
      "reason": "Regla heredada por contenido: NOTAS DE EVOLUCION -> 002.pdf",
      "score": 95
    }
  ],
  "ui": {
    "base_font_size": 13
  },
  "credits": {
    "version": "1.0",
    "author": "Equipo de implementacion",
    "organization": "",
    "description": "Herramienta para analizar, auditar y renombrar PDFs hospitalarios."
  },
  "output": {
    "audit_csv_name": "auditoria_renombrado.csv",
    "report_json_name": "auditoria_renombrado.json"
  }
}
